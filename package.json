{
  "name": "ci-on-click",
  "displayName": "CI on Click",
  "description": "Execute predefined build and test commands with a single click",
  "version": "0.0.1",
  "publisher": "myAmeDream",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/myAmeDream/ci_on_click"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ci-on-click",
          "title": "CI on Click",
          "icon": "./media/icon.svg"
        }
      ]
    },
    "views": {
      "ci-on-click": [
        {
          "id": "ci-on-click.commandsView",
          "name": "Commands"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "ci-on-click.commandsView",
        "contents": "No commands configured.\n[Open Settings](command:ci-on-click.openSettings)"
      }
    ],
    "commands": [
      {
        "command": "ci-on-click.executeCommand",
        "title": "CI: Execute Command"
      },
      {
        "command": "ci-on-click.refreshCommands",
        "title": "CI: Refresh Commands",
        "icon": "$(refresh)"
      },
      {
        "command": "ci-on-click.openSettings",
        "title": "CI: Open Settings",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ci-on-click.refreshCommands",
          "when": "view == ci-on-click.commandsView",
          "group": "navigation"
        },
        {
          "command": "ci-on-click.openSettings",
          "when": "view == ci-on-click.commandsView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "CI on Click",
      "properties": {
        "ci-on-click.commands": {
          "type": "array",
          "default": [
            {
              "name": "Build UT",
              "command": "./build.sh ut",
              "icon": "beaker"
            },
            {
              "name": "Build Clean",
              "command": "./build.sh clean",
              "icon": "trash"
            },
            {
              "name": "Build VG",
              "command": "./build.sh vg",
              "icon": "bug"
            },
            {
              "name": "Build CI",
              "command": "./build.sh ci",
              "icon": "rocket"
            }
          ],
          "description": "List of commands to execute. Each command should have a 'name', 'command', and optional 'icon' (VS Code ThemeIcon id, e.g. 'rocket', 'beaker').",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name for the command"
              },
              "command": {
                "type": "string",
                "description": "The shell command to execute"
              },
              "icon": {
                "type": "string",
                "description": "VS Code ThemeIcon id (e.g. 'rocket', 'beaker', 'bug', 'play')"
              }
            }
          }
        },
        "ci-on-click.workingDirectory": {
          "type": "string",
          "default": "${workspaceFolder}",
          "description": "Working directory for commands. Use ${workspaceFolder} for project root."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "typescript": "^4.9.3"
  }
}
